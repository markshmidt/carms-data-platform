# ── Database ──────────────────────────────────────────────────────────
# Local development (direct / Docker port-forwarded):
DATABASE_URL=postgresql://carms_user:carms_password@localhost:5432/carms_db
# Inside Docker network (set automatically by docker-compose):
# DATABASE_URL=postgresql://carms_user:carms_password@postgres:5432/carms_db

# ── Ollama ────────────────────────────────────────────────────────────
# Local:
OLLAMA_BASE_URL=http://localhost:11434
# Inside Docker:
# OLLAMA_BASE_URL=http://ollama:11434

# ── Streamlit → FastAPI ──────────────────────────────────────────────
# Local:
API_URL=http://localhost:8000
# Inside Docker:
# API_URL=http://api:8000

# ── OpenAI (optional, only if using OpenAI embeddings) ───────────────
# OPENAI_API_KEY=sk-...
